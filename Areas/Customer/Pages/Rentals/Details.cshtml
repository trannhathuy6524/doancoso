@page
@model GotoCarRental.Areas.Customer.Pages.Rentals.DetailsModel
@{
    ViewData["Title"] = $"Chi tiết đơn thuê #{Model.Rental.Id}";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-page="/Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-area="Customer" asp-page="/Rentals/Index">Đơn thuê xe</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết đơn #@Model.Rental.Id</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">Chi tiết đơn thuê #@Model.Rental.Id</h1>
            <p class="text-muted">Ngày đặt: @Model.Rental.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <div class="col-md-4 text-md-end">
            @{
                string statusClass = Model.Rental.Status switch
                {
                    0 => "warning",
                    1 => "primary",
                    2 => "danger",
                    3 => "success",
                    _ => "secondary"
                };

                string statusText = Model.Rental.Status switch
                {
                    0 => "Chờ xác nhận",
                    1 => "Đã xác nhận",
                    2 => "Đã hủy",
                    3 => "Hoàn thành",
                    _ => "Không xác định"
                };

                string paymentStatusClass = Model.Rental.PaymentStatus switch
                {
                    "Paid" => "success",
                    "Pending" => "info",
                    _ => "warning"
                };

                string paymentStatusText = Model.Rental.PaymentStatus switch
                {
                    "Paid" => "Đã thanh toán",
                    "Pending" => "Chờ xác nhận thanh toán",
                    _ => "Chờ thanh toán"
                };
            }
            <span class="badge bg-@statusClass fs-6 mb-2">@statusText</span>
            <span class="badge bg-@paymentStatusClass fs-6 d-block">@paymentStatusText</span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    


    <div class="row">
        <div class="col-lg-8">
            <!-- Thông tin xe -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Thông tin xe</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            @{
                                var imageUrl = Model.Rental.Car.CarImages != null && Model.Rental.Car.CarImages.Any()
                                    ? "/" + (Model.Rental.Car.CarImages.FirstOrDefault(ci => ci.IsMainImage) ?? Model.Rental.Car.CarImages.First()).ImageUrl.TrimStart('/')
                                    : "/images/car-placeholder.png";
                            }
                            <img src="@imageUrl" alt="@Model.Rental.Car.Name" class="img-fluid rounded mb-3">
                        </div>
                        <div class="col-md-8">
                            <h4 class="mb-2">@Model.Rental.Car.Name</h4>
                            <p class="text-muted">
                                <i class="bi bi-tag me-2"></i>@Model.Rental.Car.Brand?.Name
                                <span class="mx-2">|</span>
                                <i class="bi bi-car-front me-2"></i>@Model.Rental.Car.Category?.Name
                            </p>
                            <hr>
                            <div class="row">
                                <div class="col-6 mb-2">
                                    <span class="text-muted">Giá thuê/ngày:</span>
                                    <div>@Model.Rental.Car.PricePerDay.ToString("N0") VNĐ</div>
                                </div>
                                <div class="col-6 mb-2">
                                    <span class="text-muted">Số ngày thuê:</span>
                                    <div>@Model.RentalDays ngày</div>
                                </div>
                            </div>
                            <a asp-area="Customer" asp-page="/Cars/Details" asp-route-id="@Model.Rental.CarId" class="btn btn-outline-primary mt-2">
                                <i class="bi bi-info-circle me-2"></i>Xem chi tiết xe
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thông tin thuê -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Thông tin thuê</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6>Ngày bắt đầu</h6>
                            <p>@Model.Rental.StartDate.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="col-md-6">
                            <h6>Ngày kết thúc</h6>
                            <p>@Model.Rental.EndDate.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6>Số ngày thuê</h6>
                            <p>@Model.RentalDays ngày</p>
                        </div>
                        <div class="col-md-6">
                            <h6>Phương thức thanh toán</h6>
                            <p>@(string.IsNullOrEmpty(Model.Rental.PaymentMethod) ? "Chưa có thông tin" : Model.Rental.PaymentMethod)</p>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Ngày đặt</h6>
                            <p>@Model.Rental.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-md-6">
                            <h6>Trạng thái đơn</h6>
                            <p>
                                <span class="badge bg-@statusClass">@statusText</span>
                                <span class="badge bg-@paymentStatusClass ms-2">@paymentStatusText</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thanh toán -->
            @if (Model.Payments != null && Model.Payments.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Lịch sử thanh toán</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã</th>
                                    <th>Số tiền</th>
                                    <th>Phương thức</th>
                                    <th>Ngày thanh toán</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payment in Model.Payments)
                                {
                                    <tr>
                                        <td>#@payment.PaymentId</td>
                                        <td>@payment.Amount.ToString("N0") VNĐ</td>
                                        <td>@payment.Method</td>
                                        <td>@payment.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <!-- Trong phần hiển thị lịch sử thanh toán -->
                                        <td>
                                            @switch (payment.Status)
                                            {
                                                case "Completed":
                                                    <span class="badge bg-success">Hoàn thành</span>
                                                    break;
                                                case "Pending":
                                                    <span class="badge bg-info">Chờ xác nhận</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">@payment.Status</span>
                                                    break;
                                            }
                                        </td>

                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Khung thông báo trạng thái -->
            @switch (Model.Rental.Status)
            {
                case 0: // Chờ xác nhận
                    <div class="alert alert-warning">
                        <h5><i class="bi bi-hourglass me-2"></i>Đang chờ xác nhận</h5>
                        <p class="mb-0">Đơn thuê của bạn đang được chủ xe xem xét. Chúng tôi sẽ thông báo cho bạn khi đơn được xác nhận.</p>
                    </div>
                    break;
                case 1: // Đã xác nhận
                    <div class="alert alert-primary">
                        <h5><i class="bi bi-check-circle me-2"></i>Đơn đã được xác nhận</h5>
                        <p class="mb-0">Đơn thuê của bạn đã được xác nhận. Vui lòng đến nhận xe theo lịch hẹn.</p>
                    </div>
                    break;
                case 2: // Đã hủy
                    <div class="alert alert-danger">
                        <h5><i class="bi bi-x-circle me-2"></i>Đơn đã bị hủy</h5>
                        <p class="mb-0">Đơn thuê này đã bị hủy. Bạn có thể đặt lại hoặc tìm xe khác.</p>
                    </div>
                    break;
                case 3: // Hoàn thành
                    <div class="alert alert-success">
                        <h5><i class="bi bi-check-all me-2"></i>Đơn thuê đã hoàn thành</h5>
                        <p class="mb-0">Cảm ơn bạn đã sử dụng dịch vụ của chúng tôi. Hãy đánh giá trải nghiệm của bạn!</p>
                    </div>
                    break;
            }
        </div>

        <div class="col-lg-4">
            <!-- Tóm tắt đơn hàng -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Tóm tắt thanh toán</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3">
                        <span>Giá thuê:</span>
                        <span>@Model.Rental.Car.PricePerDay.ToString("N0") VNĐ/ngày</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Thời gian thuê:</span>
                        <span>@Model.RentalDays ngày</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold">Tổng tiền:</span>
                        <span class="fw-bold fs-5 text-primary">@Model.Rental.TotalPrice.ToString("N0") VNĐ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Trạng thái thanh toán:</span>
                        <span class="badge bg-@paymentStatusClass">@paymentStatusText</span>
                    </div>

                    @if (Model.Rental.PaymentStatus == "Pending")
                    {
                        <div class="alert alert-info mt-3">
                            <i class="bi bi-info-circle me-2"></i> Thanh toán tiền mặt của bạn đang chờ được chủ xe xác nhận.
                        </div>
                    }


                </div>
            </div>

            <!-- Thao tác -->
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Thao tác</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-area="Customer" asp-page="/Rentals/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
                        </a>
                        
                        @if (Model.CanCancel)
                        {
                            <form method="post" asp-page-handler="Cancel" asp-route-id="@Model.Rental.Id" 
                                  onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn thuê này?')">
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="bi bi-x-circle me-2"></i>Hủy đơn thuê
                                </button>
                            </form>
                        }
                        
                        @if (Model.CanPayWithCash)
                        {
                            <form method="post" asp-page-handler="PayWithCash" asp-route-id="@Model.Rental.Id">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-cash-coin me-2"></i>Thanh toán tiền mặt
                                </button>
                            </form>
                        }



                        @if (Model.CanReview)
                        {
                            <a href="/Customer/Reviews/Create/@Model.Rental.CarId" class="btn btn-outline-success">
                                <i class="bi bi-star me-2"></i>Đánh giá
                            </a>
                        }



                        
                        <a asp-area="Customer" asp-page="/Cars/Details" asp-route-id="@Model.Rental.CarId" class="btn btn-outline-primary">
                            <i class="bi bi-car-front me-2"></i>Xem lại xe
                        </a>
                        
                        @if (Model.Rental.Status == 2) // Đã hủy
                        {
                            <a asp-area="Customer" asp-page="/Cars/Index" class="btn btn-primary">
                                <i class="bi bi-search me-2"></i>Tìm xe khác
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script>
        // Tự động ẩn thông báo sau 5 giây
        setTimeout(function () {
            $('.alert-dismissible').alert('close');
        }, 5000);

        
    </script>
}

